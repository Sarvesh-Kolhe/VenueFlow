rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email is string && data.email.size() <= 256
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
        && (data.biometricSync == null || data.biometricSync is bool);
    }

    function isValidOrder(data) {
      return data.userId == request.auth.uid
        && data.standId is string && data.standId.size() <= 128
        && data.items is list && data.items.size() > 0 && data.items.size() <= 20
        && data.total is number && data.total >= 0
        && data.status in ['pending', 'authorized', 'ready', 'picked_up']
        && data.createdAt == request.time;
    }

    function isValidReport(data) {
      return data.userId == request.auth.uid
        && data.description is string && data.description.size() <= 500
        && data.location is string && data.location.size() <= 200
        && data.status in ['Searching', 'Found', 'Pending']
        && data.timestamp == request.time;
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'biometricSync']);
    }

    match /orders/{orderId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidOrder(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid 
        && isValidOrder(incoming())
        && (
           // User can cancel pending order
           (existing().status == 'pending' && incoming().status == 'cancelled' && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
           // Other state transitions would typically be handled by a backend/admin
        );
    }

    match /reports/{reportId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidReport(incoming());
      // Reports are typically immutable by users once submitted for security logs
    }
  }
}
